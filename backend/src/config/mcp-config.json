{
  "mcpServers": {
    "github": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "mcp/github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "$GITHUB_TOKEN"
      }
    },
    "neon": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "mcp/neon"],
      "env": {
        "DATABASE_URL": "$DATABASE_URL"
      }
    }
  }
}
