# =================================================================
# 🔑 LLM PROVIDER & OPENROUTER CONFIGURATION
# =================================================================
OPENROUTER_API_KEY="your_openrouter_api_key_here"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
MODEL_NAME="deepseek/deepseek-v4-flash"
APP_URL="http://localhost:5173"
MAX_RETRIES=2

# =================================================================
# 📈 TRACING & OBSERVABILITY (LANGFUSE)
# =================================================================
LANGFUSE_SECRET_KEY="your_langfuse_secret_key_here"
LANGFUSE_PUBLIC_KEY="your_langfuse_public_key_here"
LANGFUSE_BASE_URL="https://cloud.langfuse.com" # Or http://localhost:3000 for local hosting

# =================================================================
# 🤖 AGENTIC SWARM & MODEL SELECTION
# =================================================================
# DeepSeek V4 Pro/Instruct models are recommended for strict coding and architecture steps.
ARCHITECT_MODEL_NAME="deepseek/deepseek-v4-pro"
PIPELINE_MODEL_NAME="deepseek/deepseek-v4-pro"
DATAOPS_MODEL_NAME="deepseek/deepseek-v4-pro"
FORMAT_RETRY=3

# =================================================================
# ⚙️ PULUMI (INFRASTRUCTURE AS CODE)
# =================================================================
PULUMI_ACCESS_TOKEN="your_pulumi_access_token_here"
PULUMI_CONFIG_PASSPHRASE="your_secure_pulumi_passphrase"

# =================================================================
# 🔍 EXTERNAL SEARCH INTEGRATIONS
# =================================================================
TAVILY_API_KEY="your_tavily_api_key_here"

# =================================================================
# ☁️ MULTI-CLOUD CREDENTIALS
# =================================================================

# --- Amazon Web Services (AWS) ---
AWS_ACCESS_KEY_ID="your_aws_access_key_id_here"
AWS_SECRET_ACCESS_KEY="your_aws_secret_access_key_here"
AWS_REGION="us-east-1"

# --- Microsoft Azure ---
AZURE_CLIENT_ID="your_azure_client_id_here"
AZURE_CLIENT_SECRET="your_azure_client_secret_here"
AZURE_TENANT_ID="your_azure_tenant_id_here"
AZURE_SUBSCRIPTION_ID="your_azure_subscription_id_here"